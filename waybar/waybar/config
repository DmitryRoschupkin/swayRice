{
    "layer": "top",
    "position": "top",
    "height": 30,
    "modules-left": ["sway/workspaces", "sway/mode", "sway/window"],
    "modules-center": ["clock"],
    "modules-right": ["sway/language", "pulseaudio", "battery", "tray", "custom/power"],

    "sway/language": {
        "format": "🌐 {}",
        "on-click": "swaymsg input type:keyboard xkb_switch_layout next"
    },

    "clock": {
        "format": "{:%H:%M | %d.%m}",
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>"
    },

    "pulseaudio": {
        "format": "{icon} {volume}%",
	"max-volume": 100,
	"format-muted": "󰝟",
	"format-icons": {
	    "headphone": "󰋋",
	    "default": ["󰕿","󰖀","󰕾"]
	},
        "on-click": "pavucontrol",
	"on-scroll-up": "~/.config/sway/volume.sh up",
	"on-scroll-down": "pactl set-sink-volume @DEFAULT_SINK@ -5%"
    },
    "battery": {
    	"states": {
        	"warning": 30,
        	"critical": 15
    	},
    	"format": "{icon} {capacity}%",
    	"format-charging": "⚡ {capacity}%",
    	"format-plugged": " {capacity}%",
    	"format-alt": "{icon} {time}",
    	"format-icons": ["", "", "", "", ""]
    },
    "custom/power": {
    	"format": "⏻",
    	"tooltip": false,
	"on-click": "wlogout -P wayland"
	},
    "tray": {
    	"icon-size": 18,
    	"spacing": 10
    }

}
