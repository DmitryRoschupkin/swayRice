{
    "layer": "top",
    "position": "top",
    "height": 30,
    "modules-left": ["custom/tux","sway/workspaces", "sway/mode", "sway/window"],
    "modules-center": ["clock"],
    "modules-right": ["sway/language","bluetooth" ,"pulseaudio", "battery", "tray", "custom/power"],
    
    "bluetooth": {
    "format": " {status}",
    "format-connected": " {device_alias}",
    "format-connected-battery": " {device_alias} {device_battery_percentage}%",
    // "format-device-preference": [ "device1", "device2" ], // приоритетные устройства
    "tooltip-format": "{controller_alias}\t{controller_address}\n\n{num_connections} connected",
    "tooltip-format-connected": "{controller_alias}\t{controller_address}\n\n{num_connections} connected\n\n{device_enumerate}",
    "tooltip-format-enumerate-connected": "{device_alias}\t{device_address}",
    "tooltip-format-enumerate-connected-battery": "{device_alias}\t{device_address}\t{device_battery_percentage}%",
    "on-click": "blueman-manager" // или используйте "rfkill toggle bluetooth" для вкл/выкл
},

    "custom/tux":{
        "format": "",
        "tooltip": false,
        "on-click": "ptyxis --title='FedoraInfo' -- bash -c 'fastfetch; exec bash'"
    },
    "sway/language": {
        "format": "🌐 {}",
        "on-click": "swaymsg input type:keyboard xkb_switch_layout next"
    },

    "clock": {
        "format": "{:%H:%M | %d.%m}",
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>"
    },

    "pulseaudio": {
        "format": "{icon} {volume}%",
	"max-volume": 100,
	"format-muted": "󰝟",
	"format-icons": {
	    "headphone": "󰋋",
	    "default": ["󰕿","󰖀","󰕾"]
	},
        "on-click": "pavucontrol",
	"on-scroll-up": "~/.config/sway/volume.sh up",
	"on-scroll-down": "pactl set-sink-volume @DEFAULT_SINK@ -5%"
    },
    "battery": {
    	"states": {
        	"warning": 30,
        	"critical": 15
    	},
    	"format": "{icon} {capacity}%",
    	"format-charging": "⚡ {capacity}%",
    	"format-plugged": " {capacity}%",
    	"format-alt": "{icon} {time}",
    	"format-icons": ["", "", "", "", ""]
    },
    "custom/power": {
    	"format": "⏻",
    	"tooltip": false,
	"on-click": "wlogout -P wayland"
	},
    "tray": {
    	"icon-size": 18,
    	"spacing": 10
    }

}

